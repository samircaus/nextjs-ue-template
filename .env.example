# AEM endpoints for WKND content (GraphQL and assets).
# Copy to .env.local and fill in your values.

# ── Publish (required) ────────────────────────────────────────────────────────
# Default content source for all public traffic.
# Example: https://publish-pxxxx-exxxx.adobeaemcloud.com
AEM_PUBLISH_URL=

# ── Author (optional) ─────────────────────────────────────────────────────────
# Used in two scenarios:
#   1. Local / CI draft preview: set AEM_PREVIEW_MODE=true to always fetch from Author.
#   2. Universal Editor (production): UE passes the author URL at runtime via
#      the ?author=<url>&login-token=<token> query params – no env var needed.
# Example: https://author-pxxxx-exxxx.adobeaemcloud.com
AEM_AUTHOR_URL=

# Set to "true" or "1" to always use AEM Author for GraphQL (draft content).
# Use this locally when you want to preview unpublished content without opening UE.
# In production the UE iframe handles this automatically via query params.
# AEM_PREVIEW_MODE=true

# ── Universal Editor connection ───────────────────────────────────────────────
# URL injected into the urn:adobe:aue:system:aemconnection <meta> tag.
# Must point to your AEM Author instance so UE can connect to it.
# Default: https://localhost:8443
# AEM_UE_CONNECTION=https://author-pxxxx-exxxx.adobeaemcloud.com

# ── Optional overrides ────────────────────────────────────────────────────────
# Override image asset base URL (defaults to AEM_PUBLISH_URL).
# IMAGE_BASE_URL=

# Enable server-side GraphQL request logging.
# DEBUG=1
# AEM_DEBUG=1
