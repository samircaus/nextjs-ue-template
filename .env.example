# AEM endpoints for WKND content (GraphQL and assets).
# Copy to .env.local and fill in your values.

# ── Publish (required) ────────────────────────────────────────────────────────
# Default content source for all public traffic.
# Example: https://publish-pxxxx-exxxx.adobeaemcloud.com
AEM_PUBLISH_URL=

# ── Author (optional) ─────────────────────────────────────────────────────────
# Used by Universal Editor: UE passes the author URL at runtime via
# the ?author=<url>&login-token=<token> query params – no env var needed for UE.
# Set here so the AEM connection <meta> tag points to your Author instance.
# Example: https://author-pxxxx-exxxx.adobeaemcloud.com
AEM_AUTHOR_URL=

# ── Universal Editor connection ───────────────────────────────────────────────
# URL injected into the urn:adobe:aue:system:aemconnection <meta> tag.
# Must point to your AEM Author instance so UE can connect to it.
# Default: https://localhost:8443
# AEM_UE_CONNECTION=https://author-pxxxx-exxxx.adobeaemcloud.com

# ── Optional overrides ────────────────────────────────────────────────────────
# Override image asset base URL (defaults to AEM_PUBLISH_URL).
# IMAGE_BASE_URL=

# Enable server-side GraphQL request logging.
# DEBUG=1
# AEM_DEBUG=1
